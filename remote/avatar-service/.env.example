# Copy to .env before starting avatar-service.

AVATAR_ID=default-2d
AVATAR_RENDERER_MODE=parameterized_2d
AVATAR_TRANSPORT_MODE=http_poll
AVATAR_WEBSOCKET_ENDPOINT=/ws/avatar

# Runtime output directory
TMP_DIR=/root/autodl-tmp/a22/tmp/avatar

# EchoMimic
AVATAR_RENDERER_BACKEND=echomimic_v2
ECHOMIMIC_ROOT=/root/autodl-tmp/a22/models/EchoMimicV2
ECHOMIMIC_INFER_SCRIPT=infer_acc.py
ECHOMIMIC_REF_IMAGE_PATH=/root/autodl-tmp/a22/models/EchoMimicV2/assets/halfbody_demo/reference/ref.png
ECHOMIMIC_POSE_DIR=/root/autodl-tmp/a22/models/EchoMimicV2/assets/halfbody_demo/pose/01
ECHOMIMIC_TIMEOUT_SECONDS=1800

# SoulXFlashHead (low-latency clip rendering)
# Set AVATAR_RENDERER_BACKEND=soulxflashhead to enable.
SOULX_ROOT=/root/autodl-tmp/a22/models/SoulXFlashHead
SOULX_INFER_SCRIPT=infer_stream.py
SOULX_REF_IMAGE_PATH=/root/autodl-tmp/a22/models/SoulXFlashHead/assets/reference/ref.png
SOULX_TIMEOUT_SECONDS=1200
SOULX_CHUNK_SECONDS=2.0
SOULX_FPS=25
# true: return quickly and render in background; false: wait until mp4 is ready (more stable)
SOULX_ASYNC_RENDER=false
# Optional command template. If empty, default CLI is used:
# python {infer_script} --audio {audio_path} --ref-image {ref_image_path} --output {output_path} --fps {fps} --duration-seconds {chunk_seconds}
SOULX_COMMAND_TEMPLATE=
# Optional extra args appended to command.
SOULX_EXTRA_ARGS=

# CosyVoice
TTS_MODE=cosyvoice2_sft
TTS_MODEL=/root/autodl-tmp/a22/models/CosyVoice2-0.5B
TTS_DEVICE=cuda:0
TTS_REPO_PATH=/root/autodl-tmp/a22/models/CosyVoice
PYTHONPATH=/root/autodl-tmp/a22/models/CosyVoice:/root/autodl-tmp/a22/models/CosyVoice/third_party/Matcha-TTS
# Keep empty to let runtime auto-select an available speaker from model.
TTS_SPEAKER_ID=
TTS_PROMPT_WAV=
TTS_PROMPT_TEXT="YOUR_PROMPT_TEXT|endofprompt|>"
TTS_INSTRUCT_TEXT="YOUR_INSTRUCT_TEXT|endofprompt|>"
TTS_SPEED=1.0
TTS_WARMUP_ENABLED=true
