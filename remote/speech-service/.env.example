# Copy to .env before starting speech-service.

ASR_PROVIDER=belle_whisper
ASR_MODEL=/data/zifeng/siyuan/A22/models/Belle-whisper-large-v3-turbo-zh
ASR_LANGUAGE=zh
ASR_DEVICE=cuda:0
ASR_WARMUP_ENABLED=true

# Used only when ASR_PROVIDER=qwen3_asr
QWEN_ASR_USE_FLASH_ATTN=true
QWEN_ASR_USE_ITN=false

TMP_DIR=/data/zifeng/siyuan/A22/tmp/speech
